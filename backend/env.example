# Application
APP_NAME=BizLeader API
APP_VERSION=1.0.0
DEBUG=False
API_V1_PREFIX=/api/v1

# Database (PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bizledger
DB_ECHO=False

# Security
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=e-kLruG_ZEOFTDTWZ1SGSzPrAfIym59utrGjt7XgYyY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Key Security
# Generate API keys: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Multiple keys can be comma-separated
API_KEYS=your-api-key-1,your-api-key-2,your-api-key-3
API_KEY_HEADER=X-API-KEY
API_KEY_REQUIRED=true
API_KEY_PUBLIC_ENDPOINTS=/api/v1/health,/uploads

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Request Timestamp Validation (Replay Protection)
TIMESTAMP_VALIDATION_ENABLED=true
TIMESTAMP_HEADER=X-TIMESTAMP
TIMESTAMP_TOLERANCE_SECONDS=300

# IP Allowlist (Optional - leave empty to allow all IPs)
IP_ALLOWLIST_ENABLED=false
IP_ALLOWLIST=127.0.0.1,::1
REFRESH_TOKEN_EXPIRE_DAYS=7

# Super Admin Credentials
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=ChangeThisPassword123!
SUPER_ADMIN_EMAIL=admin@bizledger.com

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=5

# CORS (JSON array format)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# File Uploads
UPLOADS_DIR=uploads
ORG_LOGO_SUBDIR=organizations
ORG_LOGO_ALLOWED_EXTENSIONS=.png,.jpg,.jpeg
ORG_LOGO_ALLOWED_CONTENT_TYPES=image/png,image/jpeg
ORG_LOGO_MAX_SIZE_MB=2
